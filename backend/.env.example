# ─── App ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL) ─────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/wa_marketing

# ─── JWT Auth ─────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ─── Cloudflare R2 ────────────────────────────────────────
# Dashboard → R2 → Manage R2 API Tokens → Create Token
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=wa-marketing-media
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
# Public URL - set after enabling public access on your bucket
# e.g. https://pub-xxxxx.r2.dev  OR  https://media.yourdomain.com
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ─── PUPPETEER ────────────────────────────────────────────
PUPPETEER_SKIP_DOWNLOAD=true
